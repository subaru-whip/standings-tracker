<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.calder.standingstracker</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>/Users/digi3dprinter/Developer/standings-tracker/scan.py</string>
    <string>--publish</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>10</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/digi3dprinter/Library/Logs/standings-tracker.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/digi3dprinter/Library/Logs/standings-tracker-err.log</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
